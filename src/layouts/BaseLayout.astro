---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Ratskeller Esslingen",
  description = "Ratskeller Esslingen – fein & authentisch",
} = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
